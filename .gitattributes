# Default: auto-detect text files, store as LF in the index, LF in working tree on all platforms.
# Reason: Server~/build/* is generated by tsc (LF on every platform). Without normalization,
# Windows contributors with core.autocrlf=true produce a phantom CRLF<->LF diff after every
# `npm run build`. Pinning eol=lf removes the noise once and prevents future drift.
* text=auto eol=lf

# Source code — explicit text
*.cs        text diff=csharp
*.ts        text
*.tsx       text
*.js        text
*.jsx       text
*.mjs       text
*.cjs       text
*.json      text
*.md        text
*.yml       text
*.yaml      text
*.xml       text
*.html      text
*.css       text
*.scss      text
*.sh        text eol=lf
*.txt       text
*.gitignore text
*.gitattributes text

# Unity YAML asset files (text on disk, but Unity expects LF)
*.unity              text merge=unityyamlmerge eol=lf
*.prefab             text merge=unityyamlmerge eol=lf
*.asset              text merge=unityyamlmerge eol=lf
*.meta               text merge=unityyamlmerge eol=lf
*.controller         text merge=unityyamlmerge eol=lf
*.anim               text merge=unityyamlmerge eol=lf
